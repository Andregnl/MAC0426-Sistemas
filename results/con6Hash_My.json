    "SELECT * \n    FROM \"Posts\" \n    WHERE \"Id\" IN (\n      SELECT \"PostId\" \n      FROM \"Votes\" \n      WHERE \"UserId\" IN (\n        SELECT \"Id\" \n        FROM \"Users\" \n        WHERE \"DownVotes\" = (SELECT MAX(\"DownVotes\") FROM \"Users\")\n      )\n      AND \"VoteTypeId\" = 2\n    );": [
